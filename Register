<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Регистрация — FreeDom</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: #0b0d17;
            color: #eae6f0;
            line-height: 1.6;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .container {
            max-width: 480px;
            width: 100%;
            background: rgba(255,255,255,0.03);
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 24px;
            padding: 2rem 1.5rem;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
        }
        h1 { font-size: 1.8rem; color: #d4af37; margin-bottom: 0.5rem; text-align: center; }
        .subtitle { text-align: center; opacity: 0.6; margin-bottom: 1.5rem; font-size: 0.9rem; }
        .field { margin-bottom: 1rem; }
        .field label { display: block; font-weight: 500; margin-bottom: 4px; color: #b8a9d4; font-size: 0.9rem; }
        .field input, .field select {
            width: 100%;
            padding: 10px 14px;
            font-size: 1rem;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            background: rgba(255,255,255,0.04);
            color: #eae6f0;
            font-family: inherit;
            transition: 0.3s;
        }
        .field input:focus, .field select:focus {
            border-color: rgba(212,175,55,0.2);
            outline: none;
            background: rgba(255,255,255,0.06);
        }
        .field input::placeholder { color: rgba(255,255,255,0.2); }
        .btn {
            width: 100%;
            padding: 12px;
            background: linear-gradient(145deg, #d4af37, #b8952a);
            color: #0b0d17;
            border: none;
            border-radius: 40px;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 0.5rem;
        }
        .btn:hover { transform: scale(1.02); box-shadow: 0 4px 20px rgba(212,175,55,0.3); }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; }
        .error {
            background: rgba(255,0,0,0.1);
            border: 1px solid rgba(255,0,0,0.2);
            color: #ff6b6b;
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 0.85rem;
            margin-top: 0.5rem;
            display: none;
        }
        .success-msg {
            background: rgba(37,211,102,0.08);
            border: 1px solid rgba(37,211,102,0.15);
            color: #25D366;
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 0.85rem;
            margin-top: 0.5rem;
            display: none;
        }
        .footer-link { text-align: center; margin-top: 1.2rem; font-size: 0.9rem; opacity: 0.6; }
        .footer-link a { color: #d4af37; text-decoration: none; }
        .footer-link a:hover { text-decoration: underline; }
        .ref-hint { font-size: 0.8rem; color: #b8a9d4; margin-top: 4px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🌿 FreeDom</h1>
        <div class="subtitle">Создайте аккаунт и получайте кэшбэк</div>

        <form id="registerForm">
            <div class="field">
                <label for="displayName">Имя и фамилия</label>
                <input type="text" id="displayName" placeholder="Иван Петров" required>
            </div>
            <div class="field">
                <label for="email">Email</label>
                <input type="email" id="email" placeholder="ivan@mail.ru" required>
            </div>
            <div class="field">
                <label for="password">Пароль (мин. 6 символов)</label>
                <input type="password" id="password" placeholder="••••••" required>
            </div>
            <div class="field">
                <label for="phone">Телефон</label>
                <input type="tel" id="phone" placeholder="+7 999 123-45-67">
            </div>
            <div class="field">
                <label for="city">Город</label>
                <input type="text" id="city" placeholder="Сочи">
            </div>
            <div class="field">
                <label for="birthDate">Дата рождения</label>
                <input type="date" id="birthDate">
            </div>
            <div class="field">
                <label for="refCode">Промокод пригласившего (если есть)</label>
                <input type="text" id="refCode" placeholder="FD-12345">
                <div class="ref-hint">Если вас пригласил друг, введите его промокод</div>
            </div>

            <div id="errorMsg" class="error"></div>
            <div id="successMsg" class="success-msg">✅ Регистрация успешна! Перенаправляем...</div>

            <button type="submit" class="btn" id="submitBtn">Зарегистрироваться</button>
        </form>

        <div class="footer-link">
            Уже есть аккаунт? <a href="login.html">Войти</a>
        </div>
    </div>

    <script>
        // ===== ПОДКЛЮЧЕНИЕ К SUPABASE (КЛЮЧИ УЖЕ ВСТАВЛЕНЫ) =====
        const SUPABASE_URL = 'https://vutmbhsclmcfqqlzxqkc.supabase.co';
        const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ1dG1iaHNjbG1jZnFxbHp4cWtjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQ1ODY1OTEsImV4cCI6MjEwMDE2MjU5MX0.PxvaHbwqJjOlStrr0HQx8xulR3BLPxzm4EQWl2LFu2c';

        const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

        // Элементы формы
        const form = document.getElementById('registerForm');
        const displayNameInput = document.getElementById('displayName');
        const emailInput = document.getElementById('email');
        const passwordInput = document.getElementById('password');
        const phoneInput = document.getElementById('phone');
        const cityInput = document.getElementById('city');
        const birthDateInput = document.getElementById('birthDate');
        const refCodeInput = document.getElementById('refCode');
        const errorMsg = document.getElementById('errorMsg');
        const successMsg = document.getElementById('successMsg');
        const submitBtn = document.getElementById('submitBtn');

        // Автоподстановка промокода из URL
        const urlParams = new URLSearchParams(window.location.search);
        const refParam = urlParams.get('ref');
        if (refParam) refCodeInput.value = refParam;

        // Обработка отправки
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            errorMsg.style.display = 'none';
            successMsg.style.display = 'none';
            submitBtn.disabled = true;
            submitBtn.textContent = 'Регистрация...';

            const displayName = displayNameInput.value.trim();
            const email = emailInput.value.trim();
            const password = passwordInput.value;
            const phone = phoneInput.value.trim();
            const city = cityInput.value.trim();
            const birthDate = birthDateInput.value;
            const refCode = refCodeInput.value.trim();

            if (!displayName || !email || !password) {
                showError('Заполните имя, email и пароль.');
                submitBtn.disabled = false;
                submitBtn.textContent = 'Зарегистрироваться';
                return;
            }
            if (password.length < 6) {
                showError('Пароль должен быть не менее 6 символов.');
                submitBtn.disabled = false;
                submitBtn.textContent = 'Зарегистрироваться';
                return;
            }

            try {
                // 1. Регистрация пользователя в Supabase Auth
                const { data: authData, error: authError } = await supabase.auth.signUp({
                    email: email,
                    password: password,
                    options: {
                        data: {
                            display_name: displayName,
                            phone: phone,
                            city: city,
                            birth_date: birthDate
                        }
                    }
                });

                if (authError) throw authError;

                const userId = authData.user.id;

                // 2. Генерация промокода
                const generatedRefCode = generateRefCode(displayName);

                // 3. Поиск пригласившего по промокоду
                let referredBy = null;
                if (refCode) {
                    const { data: referrerData, error: referrerError } = await supabase
                        .from('users')
                        .select('id')
                        .eq('ref_code', refCode)
                        .maybeSingle();

                    if (!referrerError && referrerData) {
                        referredBy = referrerData.id;
                    }
                }

                // 4. Сохранение пользователя в таблицу users
                const { error: insertError } = await supabase
                    .from('users')
                    .insert({
                        id: userId,
                        email: email,
                        display_name: displayName,
                        phone: phone || null,
                        city: city || null,
                        birth_date: birthDate || null,
                        ref_code: generatedRefCode,
                        referred_by: referredBy,
                        balance: 0
                    });

                if (insertError) throw insertError;

                // 5. Если есть пригласивший — создаём запись в referrals (уровень 1)
                if (referredBy) {
                    await supabase
                        .from('referrals')
                        .insert({
                            referrer_id: referredBy,
                            referee_id: userId,
                            level: 1
                        });
                }

                // Успех
                successMsg.style.display = 'block';
                submitBtn.textContent = 'Готово!';
                submitBtn.disabled = true;
                setTimeout(() => {
                    window.location.href = 'profile.html';
                }, 2000);

            } catch (error) {
                console.error('Ошибка:', error);
                let message = error.message || 'Ошибка регистрации.';
                if (error.message?.includes('already registered')) {
                    message = 'Этот email уже зарегистрирован.';
                }
                showError(message);
                submitBtn.disabled = false;
                submitBtn.textContent = 'Зарегистрироваться';
            }
        });

        function generateRefCode(displayName) {
            const namePart = displayName.replace(/[^a-zA-Zа-яА-Я]/g, '').slice(0, 4).toUpperCase() || 'USER';
            const randomPart = Math.floor(1000 + Math.random() * 9000);
            return `FD-${namePart}${randomPart}`;
        }

        function showError(msg) {
            errorMsg.textContent = msg;
            errorMsg.style.display = 'block';
        }
    </script>
</body>
</html>
